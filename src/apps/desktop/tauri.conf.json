{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "taiji-quant",
  "identifier": "com.taiji.quant",
  "build": {
    "beforeDevCommand": "pnpm run dev:web",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "pnpm run build:web && pnpm run prepare:mobile-web",
    "frontendDist": "../../../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Taiji Quant Team",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": {
      "../../mobile-web/dist": "mobile-web/dist",
      "resources/worker_host.js": "resources/worker_host.js"
    },
    "linux": {
      "deb": {
        "depends": [
          "libc6",
          "libcairo2",
          "libgcc-s1",
          "libgdk-pixbuf-2.0-0",
          "libglib2.0-0",
          "libjavascriptcoregtk-4.1-0",
          "liblept5",
          "liblzma5",
          "libsoup-3.0-0",
          "libtesseract5",
          "libxcb1",
          "libxdo3",
          "tesseract-ocr-eng",
          "zlib1g"
        ],
        "files": {
          "/usr/share/icons/hicolor/16x16/apps/taiji-quant.png": "icons/hicolor/16x16/apps/taiji-quant.png",
          "/usr/share/icons/hicolor/32x32/apps/taiji-quant.png": "icons/hicolor/32x32/apps/taiji-quant.png",
          "/usr/share/icons/hicolor/48x48/apps/taiji-quant.png": "icons/hicolor/48x48/apps/taiji-quant.png",
          "/usr/share/icons/hicolor/64x64/apps/taiji-quant.png": "icons/hicolor/64x64/apps/taiji-quant.png",
          "/usr/share/icons/hicolor/96x96/apps/taiji-quant.png": "icons/hicolor/96x96/apps/taiji-quant.png",
          "/usr/share/icons/hicolor/128x128/apps/taiji-quant.png": "icons/hicolor/128x128/apps/taiji-quant.png",
          "/usr/share/icons/hicolor/256x256/apps/taiji-quant.png": "icons/hicolor/256x256/apps/taiji-quant.png",
          "/usr/share/icons/hicolor/512x512/apps/taiji-quant.png": "icons/hicolor/512x512/apps/taiji-quant.png"
        },
        "postInstallScript": "scripts/post-install-icons.sh"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true,
    "withGlobalTauri": true
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": ""
    }
  }
}
